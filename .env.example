# ACHABITATION — exemple de variables pour Docker / profil prod
# Copier ce fichier en .env localement, puis remplacer les valeurs d'exemple.
SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://postgres:5432/achabitation
DATABASE_USER=achabitation
DATABASE_PASSWORD=replace-with-a-real-strong-password
PORT=8080
CORS_ALLOWED_ORIGINS=https://app.example.com
APP_PUBLIC_URL=https://app.example.com
# À fournir quand un adaptateur email est branché pour le reset password.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
MAIL_FROM=no-reply@example.com
RESET_PASSWORD_PUBLIC_URL=https://app.example.com/reset-password
APP_EMAIL_VERIFICATION_URL=https://app.example.com/verify-email
# Android release : passer via variable d'environnement ou propriété Gradle au build.
ACHABITATION_API_BASE_URL=https://api.example.com/api/v1
