# ACHABITATION - exemple de configuration prod/preprod.
# Copier ce fichier vers .env.prod et remplacer toutes les valeurs placeholder.
# Ne jamais commiter .env.prod.

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Base PostgreSQL interne Docker. Le service postgres n'expose pas le port 5432 publiquement.
DATABASE_URL=jdbc:postgresql://postgres:5432/achabitation
DATABASE_USER=achabitation
DATABASE_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# Front public autorisé à appeler l'API.
# Exemple local/tunnel : https://achabitation.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

# URL publique utilisée dans les emails de vérification/reset.
APP_PUBLIC_URL=https://app.example.com

# SMTP réel requis en profil prod avec require-email-verification=true.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
MAIL_FROM=no-reply@example.com
